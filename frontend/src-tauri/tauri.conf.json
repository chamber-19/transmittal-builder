{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "R3P Transmittal Builder",
  "version": "4.0.0",
  "identifier": "com.root3power.transmittal-builder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "R3P Transmittal Builder",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "dragDropEnabled": false,
        "visible": false
      },
      {
        "label": "updater",
        "title": "Transmittal Builder — Update",
        "url": "updater.html",
        "width": 520,
        "height": 320,
        "decorations": false,
        "resizable": false,
        "center": true,
        "visible": false
      },
      {
        "label": "splash",
        "title": "Transmittal Builder",
        "url": "splash.html",
        "width": 560,
        "height": 340,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/transmittal-backend/**/*"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "languages": ["English"]
      }
    }
  }
}
