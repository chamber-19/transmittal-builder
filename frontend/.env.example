# Backend API URL
VITE_API_URL=http://localhost:8000

# Google OAuth Client ID (must match backend's GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Default root folder scanned for active projects on the Projects page
# Leave empty to disable the auto-scan (users can still open individual folders)
VITE_DEFAULT_PROJECTS_ROOT=
