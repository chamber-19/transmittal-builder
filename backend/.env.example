# Google OAuth — required unless DISABLE_AUTH=1
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Access control — comma-separated allow-list; empty = any verified Google user
ALLOWED_EMAILS=user@example.com

# CORS — comma-separated origins the frontend is served from
ALLOWED_ORIGINS=http://localhost:5173

# Set to 1 to bypass auth in local dev only — never set to 1 in production
DISABLE_AUTH=0

# Set by CI from the git tag; returns "dev" locally — do not set manually
# APP_VERSION=dev

# Email sending — required only if /api/email is used
SMTP_SENDER=
SMTP_PASSWORD=

# Developer-only features (delete from recent, is_developer flag in /api/auth/me)
# Leave empty to disable developer mode entirely
DEVELOPER_EMAIL=
